rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own library.
    // Unauthenticated requests are completely blocked.
    match /users/{userId}/library/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Users can only read and write their own liked songs.
    match /users/{userId}/liked/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Block all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

