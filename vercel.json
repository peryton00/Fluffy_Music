{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/__/auth/(.*)",
      "destination": "https://fluffy-music-86492.firebaseapp.com/__/auth/$1"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/app",
      "dest": "/app.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
