# Fluffy Music — Environment Variables
# Copy this file to .env and fill in your values for local development.
# For production, add these via the Vercel dashboard (Project → Settings → Environment Variables).

# ── Spotify ──────────────────────────────────────────────────────────────────
# Get from: https://developer.spotify.com/dashboard → Your App → Settings
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── App URL ───────────────────────────────────────────────────────────────────
# Your deployed Vercel URL (used for CORS reference)
APP_URL=https://your-project.vercel.app
